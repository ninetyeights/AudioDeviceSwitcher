<Window x:Class="AudioDeviceSwitcher.ProfileEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="配置设置" Height="500" Width="520"
        Icon="pack://application:,,,/Resources/app.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="名称:" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="NameBox" FontSize="14" Padding="4" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="快捷键:" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="HotkeyBox" FontSize="14" Padding="4"
                     IsReadOnly="True" PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                     GotFocus="HotkeyBox_GotFocus" LostFocus="HotkeyBox_LostFocus"
                     Text="点击设置快捷键" Foreground="Gray"/>
            <Button Grid.Column="1" Content="清除" Padding="8,2" Margin="6,0,0,0" Click="ClearHotkey_Click"/>
        </Grid>

        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,4,0,8">
            <CheckBox x:Name="VoicemeeterRestartCheck"
                      Content="切换后重启 Voicemeeter 音频引擎（未运行则跳过）"
                      Margin="0,0,0,4" VerticalAlignment="Center"/>
            <CheckBox x:Name="ShowInMiniWindowCheck"
                      Content="在迷你窗口中显示"
                      Margin="0,0,0,6" VerticalAlignment="Center"/>
            <DockPanel>
                <TextBlock Text="标签颜色:" VerticalAlignment="Center" Margin="0,0,8,0" DockPanel.Dock="Left"/>
                <StackPanel x:Name="ColorPicker" Orientation="Horizontal"/>
            </DockPanel>
        </StackPanel>

        <DockPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,8,0,6">
            <TextBlock Text="应用覆盖" FontSize="13" FontWeight="SemiBold" DockPanel.Dock="Left" VerticalAlignment="Center"/>
            <Button Content="添加" Padding="8,2" Margin="12,0,0,0" HorizontalAlignment="Left" Click="AddOverride_Click"/>
            <TextBlock Text="切换本配置时，会为列出的运行中应用单独设置音频设备"
                       FontSize="11" Foreground="#777" Margin="12,0,0,0" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
        </DockPanel>

        <Border Grid.Row="4" Grid.ColumnSpan="2" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="EmptyOverrideHint" Text="没有应用覆盖。点上面的&quot;添加&quot;新增一条。"
                               FontSize="12" Foreground="#999" HorizontalAlignment="Center" Margin="0,20"
                               Visibility="Visible"/>
                    <ItemsControl x:Name="OverrideList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding ExeDisplay}" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding ProfileDisplay}" FontSize="11" Foreground="#666"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="编辑" Padding="8,2" Margin="0,0,6,0"
                                            Tag="{Binding ExePath}" Click="EditOverride_Click"/>
                                    <Button Grid.Column="2" Content="删除" Padding="8,2" Foreground="#D32F2F"
                                            Tag="{Binding ExePath}" Click="DeleteOverride_Click"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="确定" Width="80" Margin="0,0,8,0" Click="OK_Click" IsDefault="True"/>
            <Button Content="取消" Width="80" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
