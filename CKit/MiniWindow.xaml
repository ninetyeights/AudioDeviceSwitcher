<Window x:Class="AudioDeviceSwitcher.MiniWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="&#x97F3;&#x9891;&#x5207;&#x6362;&#x52A9;&#x624B;" Height="200" Width="220" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="NoResize"
        Background="Transparent" AllowsTransparency="True" Topmost="True"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown">
    <Window.Resources>
        <Style x:Key="MiniProfileButton" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,2,4,2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F4F6"/>
                    <Setter Property="BorderBrush" Value="#D1D5DB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="MiniActiveProfileButton" TargetType="Button" BasedOn="{StaticResource MiniProfileButton}">
            <Setter Property="Background" Value="#EFF6FF"/>
            <Setter Property="BorderBrush" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="BorderBrush" Value="#2563EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Background="#FFFFFF" Padding="8" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.18" BlurRadius="14" ShadowDepth="2" Direction="270"/>
        </Border.Effect>
      <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <CheckBox x:Name="LockCheck" Content="&#x9501;&#x5B9A;" VerticalAlignment="Center" IsChecked="True"
                      FontSize="11" Foreground="#6B7280"
                      Checked="Lock_Changed" Unchecked="Lock_Changed"/>
            <TextBlock Text="&#x900F;&#x660E;&#x5EA6;" VerticalAlignment="Center" Margin="12,0,6,0" FontSize="11"
                       Foreground="#6B7280"/>
            <Slider x:Name="OpacitySlider" Width="70" Minimum="0.3" Maximum="1.0" Value="1.0"
                    VerticalAlignment="Center" ValueChanged="Opacity_Changed"/>
        </StackPanel>

        <!-- Profile List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ProfileList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" x:Name="BluetoothWarning" Background="#FFFBEB" BorderBrush="#FCD34D"
                BorderThickness="1" CornerRadius="3" Padding="6,3" Margin="0,4,0,0"
                HorizontalAlignment="Stretch" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Ellipse Width="5" Height="5" Fill="#D97706" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBlock Text="&#x84DD;&#x7259;&#x5DF2;&#x8FDE;&#x63A5;" FontSize="10" Foreground="#92400E" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="3" x:Name="WarningText" Background="#FEF2F2" BorderBrush="#FECACA"
                BorderThickness="1" CornerRadius="3" Padding="6,3" Margin="0,4,0,0"
                HorizontalAlignment="Stretch" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Ellipse Width="5" Height="5" Fill="#DC2626" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBlock Text="&#x5F53;&#x524D;&#x8BBE;&#x5907;&#x4E0D;&#x5339;&#x914D;&#x4EFB;&#x4F55;&#x914D;&#x7F6E;"
                           FontSize="10" Foreground="#991B1B" VerticalAlignment="Center"/>
            </StackPanel>
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <Trigger Property="Tag" Value="Blink">
                            <Trigger.EnterActions>
                                <BeginStoryboard Name="MiniWarningBlink">
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="1.0" To="0.55" Duration="0:0:0.8"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="MiniWarningBlink"/>
                            </Trigger.ExitActions>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>
        <TextBlock Grid.Row="4" x:Name="AppDriftWarning"
                   FontSize="10" Foreground="#92400E" HorizontalAlignment="Center"
                   Margin="0,4,0,0" Visibility="Collapsed" TextTrimming="CharacterEllipsis"/>
        <TextBlock Grid.Row="5" x:Name="EmptyHint" Text="&#x6682;&#x65E0;&#x914D;&#x7F6E;" FontSize="11"
                   Foreground="#9CA3AF" HorizontalAlignment="Center" Margin="0,10,0,0"
                   Visibility="Collapsed"/>
      </Grid>
    </Border>
</Window>
