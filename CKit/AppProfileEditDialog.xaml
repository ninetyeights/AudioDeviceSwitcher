<Window x:Class="AudioDeviceSwitcher.AppProfileEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="应用配置" Height="230" Width="400"
        Icon="pack://application:,,,/Resources/app.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="名称:" VerticalAlignment="Center" Margin="0,0,8,10"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="NameBox" FontSize="14" Padding="4" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="输出:" VerticalAlignment="Center" Margin="0,0,8,10"/>
        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="OutputBox" FontSize="13" Padding="4" Margin="0,0,0,10"
                  DisplayMemberPath="Name"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="输入:" VerticalAlignment="Center" Margin="0,0,8,10"/>
        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="InputBox" FontSize="13" Padding="4" Margin="0,0,0,10"
                  DisplayMemberPath="Name"/>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确定" Width="80" Margin="0,0,8,0" Click="OK_Click" IsDefault="True"/>
            <Button Content="取消" Width="80" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
