<Window x:Class="AudioDeviceSwitcher.AppOverrideEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="应用覆盖" Height="310" Width="480"
        Icon="pack://application:,,,/Resources/app.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="应用来源" FontWeight="SemiBold" Margin="0,0,0,6"/>

        <RadioButton Grid.Row="1" x:Name="FromSessionRadio" Content="从当前正在播放音频的会话选择"
                     GroupName="Source" IsChecked="True" Margin="0,0,0,6"
                     Checked="SourceRadio_Changed"/>
        <ComboBox Grid.Row="2" x:Name="SessionBox" Padding="4" Margin="24,0,0,10"
                  DisplayMemberPath="DisplayName" IsEnabled="{Binding IsChecked, ElementName=FromSessionRadio}"/>

        <RadioButton Grid.Row="3" x:Name="FromFileRadio" Content="手动选择可执行文件"
                     GroupName="Source" Margin="0,0,0,6" Checked="SourceRadio_Changed"/>
        <Grid Grid.Row="4" Margin="24,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="ExePathBox" Padding="4"
                     IsEnabled="{Binding IsChecked, ElementName=FromFileRadio}"/>
            <Button Grid.Column="1" Content="浏览..." Padding="12,2" Margin="6,0,0,0"
                    IsEnabled="{Binding IsChecked, ElementName=FromFileRadio}" Click="Browse_Click"/>
        </Grid>

        <TextBlock Grid.Row="5" Text="应用配置" FontWeight="SemiBold" Margin="0,6,0,6"/>
        <ComboBox Grid.Row="6" x:Name="AppProfileBox" VerticalAlignment="Top" Padding="4"
                  DisplayMemberPath="Name"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="确定" Width="80" Margin="0,0,8,0" Click="OK_Click" IsDefault="True"/>
            <Button Content="取消" Width="80" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
