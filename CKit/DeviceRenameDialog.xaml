<Window x:Class="AudioDeviceSwitcher.DeviceRenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="重命名设备" Height="180" Width="400"
        Icon="pack://application:,,,/Resources/app.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="OriginalNameBlock" FontSize="12" Foreground="#666"
                   TextTrimming="CharacterEllipsis" Margin="0,0,0,8"/>

        <TextBox Grid.Row="1" x:Name="NicknameBox" FontSize="14" Padding="4"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="清除名称" Padding="8,4" Margin="0,0,8,0" Click="Clear_Click"/>
            <Button Content="确定" Width="80" Margin="0,0,8,0" Click="OK_Click" IsDefault="True"/>
            <Button Content="取消" Width="80" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
