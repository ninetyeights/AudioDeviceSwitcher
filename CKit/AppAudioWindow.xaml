<Window x:Class="AudioDeviceSwitcher.AppAudioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="应用音频" Height="520" Width="680"
        Icon="pack://application:,,,/Resources/app.ico"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="13" Foreground="#555" TextWrapping="Wrap" Margin="0,0,0,8">
            为每个应用单独指定输出/输入设备。"跟随系统" 表示使用系统默认设备。设置由 Windows 保存，下次启动该应用时自动生效。
        </TextBlock>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="刷新" Padding="12,4" Click="Refresh_Click"/>
            <Button Content="清除全部应用覆盖" Padding="12,4" Margin="8,0,0,0" Click="ClearAll_Click"
                    Foreground="#D32F2F"/>
            <TextBlock x:Name="EmptyHint" Text="没有检测到正在播放音频的应用（让应用播放点声音再刷新）"
                       VerticalAlignment="Center" Margin="12,0,0,0" FontSize="12" Foreground="#999"
                       Visibility="Collapsed"/>
        </StackPanel>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="SessionList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="6" Padding="10,8" Margin="0,0,0,6" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#FAFAFA"/>
                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDrifted}" Value="True">
                                            <Setter Property="Background" Value="#FFEBEE"/>
                                            <Setter Property="BorderBrush" Value="#D32F2F"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Image Grid.Column="0" Source="{Binding Icon}" Width="28" Height="28"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{Binding SubText}" FontSize="11" Foreground="#777"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="输出" FontSize="10" Foreground="#666"/>
                                        <TextBlock Text=" ⚠ 偏离" FontSize="10" Foreground="#D32F2F" FontWeight="Bold"
                                                   Visibility="{Binding IsOutputDrifted, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                    <ComboBox Width="180" ItemsSource="{Binding OutputOptions}"
                                              SelectedItem="{Binding SelectedOutput, Mode=TwoWay}"
                                              DisplayMemberPath="Name">
                                        <ComboBox.Style>
                                            <Style TargetType="ComboBox">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOutputDrifted}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#D32F2F"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ComboBox.Style>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="4,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="输入" FontSize="10" Foreground="#666"/>
                                        <TextBlock Text=" ⚠ 偏离" FontSize="10" Foreground="#D32F2F" FontWeight="Bold"
                                                   Visibility="{Binding IsInputDrifted, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                    <ComboBox Width="180" ItemsSource="{Binding InputOptions}"
                                              SelectedItem="{Binding SelectedInput, Mode=TwoWay}"
                                              DisplayMemberPath="Name">
                                        <ComboBox.Style>
                                            <Style TargetType="ComboBox">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsInputDrifted}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#D32F2F"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ComboBox.Style>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <DockPanel Grid.Row="3" Margin="0,8,0,0">
            <Button Content="关闭" Padding="16,6" HorizontalAlignment="Right" DockPanel.Dock="Right"
                    Click="Close_Click"/>
        </DockPanel>
    </Grid>
</Window>
